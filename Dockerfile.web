FROM ghcr.io/cirruslabs/flutter:stable AS build

WORKDIR /app

COPY flutter_app /app/flutter_app
COPY scripts /app/scripts

WORKDIR /app/flutter_app
RUN flutter pub get

ARG API_BASE_URL=http://localhost:8000
RUN python3 /app/scripts/flutter_build.py web --release --dart-define=API_BASE_URL=${API_BASE_URL}

FROM python:3.12-slim

WORKDIR /app
COPY --from=build /app/flutter_app/build/web /app
COPY scripts/write_frontend_config.py /usr/local/bin/write_frontend_config.py

EXPOSE 8080
CMD ["sh", "-c", "python /usr/local/bin/write_frontend_config.py && python -m http.server ${PORT:-8080} --bind 0.0.0.0 --directory /app"]
